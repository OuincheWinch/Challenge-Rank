{
  "manifest_version": 3,
  "name": "Challenge Rank",
  "version": "2.1.0",
  "description": "Sort Civitai challenge images by rank/score with judge details popup.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "cookies",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://civitai.com/*",
    "https://civitai.green/*",
    "https://civitai.red/*",
    "https://www.ouinche.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://civitai.com/*",
        "https://civitai.green/*",
        "https://civitai.red/*"
      ],
      "js": [
        "scanner.js",
        "popup.js",
        "overlay.js",
        "controls.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ]
}