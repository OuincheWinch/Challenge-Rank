{
  "manifest_version": 3,
  "name": "Challenge Rank",
  "version": "2.0.0",
  "description": "Sort Civitai challenge images by rank/score with judge details popup.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "cookies",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://civitai.com/*",
    "https://www.ouinche.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "challenge-rank@ouinche.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://civitai.com/*"
      ],
      "js": [
        "scanner.js",
        "popup.js",
        "overlay.js",
        "controls.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ]
}